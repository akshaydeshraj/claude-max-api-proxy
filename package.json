{
  "name": "claude-max-proxy",
  "version": "1.0.0",
  "description": "OpenAI-compatible proxy for Claude Max subscription via Agent SDK",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/dashboard dist/",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run src/integration/ --testTimeout=120000"
  },
